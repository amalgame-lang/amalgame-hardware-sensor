// Test sensor drivers against fake HAL backends (no hardware).

namespace Tests

import Amalgame.Hal
import Amalgame.Hardware.Sensor

// Fake SPI that echoes a fixed MCP3008 reply (0x03FF = 1023).
public class FakeSpi implements SpiBus {
    public FakeSpi() { }
    public List<int> Transfer(tx: List<int>) {
        let r: List<int> = new List<int>()
        r.Add(0)
        r.Add(3)
        r.Add(255)
        return r
    }
}

// Fake I2C reporting the BME280 chip id (0xD0 → 0x60).
public class FakeI2c implements I2cBus {
    public FakeI2c() { }
    public bool WriteByte(addr: int, value: int) { return true }
    public int  ReadByte(addr: int) { return 0 }
    public bool WriteReg(addr: int, reg: int, value: int) { return true }
    public int  ReadReg(addr: int, reg: int) {
        if (reg == 208) { return 0x60 }   // BME280 chip id
        if (reg == 117) { return 0x68 }   // MPU6050 WHO_AM_I
        return 0
    }
    public bool WriteBytes(addr: int, bytes: List<int>) { return true }
    public List<int> ReadBytes(addr: int, count: int) {
        // Canned burst: byte0=1 → first 16-bit word = 0x0100 = 256.
        let l: List<int> = new List<int>()
        var i: int = 0
        while (i < count) {
            if (i == 0) { l.Add(1) } else { l.Add(0) }
            i = i + 1
        }
        return l
    }
}

// Fake clock whose Micros() advances 1 ms per call → HC-SR04 times out.
public class FakeClock implements Clock {
    private t: int
    public FakeClock() { this.t = 0 }
    public void DelayMs(ms: int) { }
    public void DelayUs(us: int) { }
    public int Millis() { return 0 }
    public int Micros() { this.t = this.t + 1000; return this.t }
}

public class FakeIn implements DigitalIn {
    public FakeIn() { }
    public int Read() { return 0 }   // never echoes; HX711: ready + data 0
}

// SPI fake returning a fixed MAX6675 word 0x4000 → 2048 code → 512.00°C.
public class FakeSpiTemp implements SpiBus {
    public FakeSpiTemp() { }
    public List<int> Transfer(tx: List<int>) {
        let r: List<int> = new List<int>()
        r.Add(0x40)
        r.Add(0x00)
        return r
    }
}
public class FakeOut implements DigitalOut {
    public FakeOut() { }
    public void Write(level: int) { }
    public void High() { }
    public void Low()  { }
    public void Toggle() { }
}

// SHT31 fake: ReadBytes → traw=0x6666, hraw=0x8000 (CRC bytes ignored).
public class FakeSht implements I2cBus {
    public FakeSht() { }
    public bool WriteByte(addr: int, value: int) { return true }
    public int  ReadByte(addr: int) { return 0 }
    public bool WriteReg(addr: int, reg: int, value: int) { return true }
    public int  ReadReg(addr: int, reg: int) { return 0 }
    public bool WriteBytes(addr: int, bytes: List<int>) { return true }
    public List<int> ReadBytes(addr: int, count: int) {
        let l: List<int> = new List<int>()
        l.Add(0x66); l.Add(0x66); l.Add(0)     // temp + crc
        l.Add(0x80); l.Add(0x00); l.Add(0)     // hum  + crc
        return l
    }
}

// AHT20 fake: status ok, hum raw 0x80000, temp raw 0x60000.
public class FakeAht implements I2cBus {
    public FakeAht() { }
    public bool WriteByte(addr: int, value: int) { return true }
    public int  ReadByte(addr: int) { return 0 }
    public bool WriteReg(addr: int, reg: int, value: int) { return true }
    public int  ReadReg(addr: int, reg: int) { return 0 }
    public bool WriteBytes(addr: int, bytes: List<int>) { return true }
    public List<int> ReadBytes(addr: int, count: int) {
        let l: List<int> = new List<int>()
        l.Add(0x1C)                            // status (not busy)
        l.Add(0x80); l.Add(0x00); l.Add(0x06)  // hum[19:4] + shared nibble
        l.Add(0x00); l.Add(0x00)               // temp[15:0]
        l.Add(0)                               // crc
        return l
    }
}

public class Program {
    public static void Main(string[] args) {
        var fail: int = 0

        let adc: Mcp3008 = new Mcp3008(new FakeSpi())
        if (adc.Read(0) == 1023) { Console.WriteLine("[PASS] mcp3008 reads 1023") } else { Console.WriteLine("[FAIL] mcp3008 got " + String_FromInt(adc.Read(0))); fail = fail + 1 }
        if (adc.Read(9) == (0 - 1)) { Console.WriteLine("[PASS] mcp3008 bad channel") } else { Console.WriteLine("[FAIL] mcp3008 bad channel"); fail = fail + 1 }

        let d: Hcsr04 = new Hcsr04(new FakeOut(), new FakeIn(), new FakeClock())
        if (d.ReadCm() == (0 - 1)) { Console.WriteLine("[PASS] hcsr04 timeout = -1") } else { Console.WriteLine("[FAIL] hcsr04 timeout"); fail = fail + 1 }

        let env: Bme280 = new Bme280(new FakeI2c(), 0x76)
        if (env.IsPresent()) { Console.WriteLine("[PASS] bme280 chip id") } else { Console.WriteLine("[FAIL] bme280 chip id"); fail = fail + 1 }

        let imu: Mpu6050 = new Mpu6050(new FakeI2c(), 0x68)
        if (imu.IsPresent()) { Console.WriteLine("[PASS] mpu6050 who-am-i") } else { Console.WriteLine("[FAIL] mpu6050 who-am-i"); fail = fail + 1 }
        imu.Read()
        if (imu.AccelX() == 256) { Console.WriteLine("[PASS] mpu6050 accelX burst") } else { Console.WriteLine("[FAIL] mpu6050 accelX got " + String_FromInt(imu.AccelX())); fail = fail + 1 }

        // INA219: canned reg 0x02 = 0x0100 → bus mV = (256/8)*4 = 128.
        let pm: Ina219 = new Ina219(new FakeI2c(), 0x40)
        if (pm.BusMilliVolts() == 128) { Console.WriteLine("[PASS] ina219 bus mV") } else { Console.WriteLine("[FAIL] ina219 bus mV got " + String_FromInt(pm.BusMilliVolts())); fail = fail + 1 }

        // ADS1115: canned conv reg 0x0100 = 256 → 256/8 = 32 mV.
        let ads: Ads1115 = new Ads1115(new FakeI2c(), 0x48, new FakeClock())
        if (ads.ReadMilliVolts(0) == 32) { Console.WriteLine("[PASS] ads1115 mV") } else { Console.WriteLine("[FAIL] ads1115 mV got " + String_FromInt(ads.ReadMilliVolts(0))); fail = fail + 1 }

        // HX711: data line stuck low → ready + 24 zero bits → raw 0.
        let scale: Hx711 = new Hx711(new FakeOut(), new FakeIn(), new FakeClock())
        if (scale.IsReady() && scale.ReadRaw() == 0) { Console.WriteLine("[PASS] hx711 read") } else { Console.WriteLine("[FAIL] hx711 read"); fail = fail + 1 }

        // MAX6675: canned 0x4000 → code 2048 → 512.00 °C → 51200 centi.
        let tc: Max6675 = new Max6675(new FakeSpiTemp())
        if (tc.TempCenti() == 51200) { Console.WriteLine("[PASS] max6675 512C") } else { Console.WriteLine("[FAIL] max6675 got " + String_FromInt(tc.TempCenti())); fail = fail + 1 }

        // SHT31: traw=0x6666 → 25.00 °C ; hraw=0x8000 → 50.00 %RH.
        let sht: Sht31 = new Sht31(new FakeSht(), 0x44)
        let _sr: bool = sht.Read()
        if (sht.TempCenti() == 2500 && sht.HumidityCenti() == 5000) { Console.WriteLine("[PASS] sht31 25.00C/50%") } else { Console.WriteLine("[FAIL] sht31 t=" + String_FromInt(sht.TempCenti()) + " h=" + String_FromInt(sht.HumidityCenti())); fail = fail + 1 }

        // AHT20: temp raw 0x60000 → 25.00 °C ; hum raw 0x80000 → 50.00 %RH.
        let aht: Aht20 = new Aht20(new FakeAht(), new FakeClock())
        let _ar: bool = aht.Read()
        if (aht.TempCenti() == 2500 && aht.HumidityCenti() == 5000) { Console.WriteLine("[PASS] aht20 25.00C/50%") } else { Console.WriteLine("[FAIL] aht20 t=" + String_FromInt(aht.TempCenti()) + " h=" + String_FromInt(aht.HumidityCenti())); fail = fail + 1 }

        // DS18B20: write a fake sysfs w1_slave file, parse t=23456 → 23.45 °C.
        let w1: string = "ds18b20_test.w1"
        let _w1: bool = File.WriteAll(w1, "a1 01 4b 46 7f ff 0c 10 1e : crc=2f YES\na1 01 4b 46 7f ff 0c 10 1e t=23456\n")
        let probe: Ds18b20 = new Ds18b20(w1)
        if (probe.TempCenti() == 2345) { Console.WriteLine("[PASS] ds18b20 23.45C") } else { Console.WriteLine("[FAIL] ds18b20 got " + String_FromInt(probe.TempCenti())); fail = fail + 1 }

        if (fail == 0) { Console.WriteLine("sensor: all good") }
    }
}
